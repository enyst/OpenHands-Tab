{
  "name": "openhands-tab",
  "displayName": "OpenHands Tab",
  "publisher": "openhands",
  "version": "0.0.2",
  "description": "A VS Code extension to interact with OpenHands agent-server in a dedicated tab",
  "license": "MIT",
  "engines": {
    "vscode": "^1.104.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:openhands.openTab",
    "onCommand:openhands.startNewConversation",
    "onCommand:openhands.configure",
    "onCommand:openhands.reconnect",
    "onCommand:openhands.pauseCurrentRun"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openhands.openTab",
        "title": "OpenHands: Open Tab"
      },
      {
        "command": "openhands.startNewConversation",
        "title": "OpenHands: Start New Conversation"
      },
      {
        "command": "openhands.configure",
        "title": "OpenHands: Configure"
      },
      {
        "command": "openhands.reconnect",
        "title": "OpenHands: Reconnect"
      },
      {
        "command": "openhands.pauseCurrentRun",
        "title": "OpenHands: Pause Current Run"
      },
      {
        "command": "openhands._diagnostics",
        "title": "OpenHands: Diagnostics (Internal)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "OpenHands Tab",
      "properties": {
        "openhands.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "OpenHands agent-server base URL"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . && tsc -p tsconfig.webview.json",
    "watch": "tsc -w -p . & tsc -w -p tsconfig.webview.json",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "e2e": "npm run compile && mocha -r ts-node/register tests/e2e/**/*.test.ts && tsc -p tsconfig.e2e.json"
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p . && tsc -p tsconfig.webview.json"
  },
  "files": [
    "dist/**",
    "media/**",
    "node_modules/ws/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "bundledDependencies": [
    "ws"
  ],
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/vscode": "^1.104.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.6.1",
    "@vitest/coverage-v8": "^2.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "eslint": "^9.36.0",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.2",
    "vitest": "^2.1.4",
    "esbuild": "^0.23.1"
  },
  "dependencies": {
    "ws": "^8.18.3"
  }
}
