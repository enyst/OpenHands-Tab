{
  "name": "openhands-tab",
  "displayName": "OpenHands Tab",
  "publisher": "openhands",
  "version": "0.0.3",
  "description": "A VS Code extension to interact with OpenHands agent-server in a dedicated tab",
  "license": "MIT",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openhands.openTab",
        "title": "OpenHands: Open Tab"
      },
      {
        "command": "openhands.startNewConversation",
        "title": "OpenHands: Start New Conversation"
      },
      {
        "command": "openhands.configure",
        "title": "OpenHands: Configure"
      },
      {
        "command": "openhands.reconnect",
        "title": "OpenHands: Reconnect"
      },
      {
        "command": "openhands.pauseCurrentRun",
        "title": "OpenHands: Pause Current Run"
      },
      {
        "command": "openhands._diagnostics",
        "title": "OpenHands: Diagnostics (Internal)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "OpenHands Tab",
      "properties": {
        "openhands.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "OpenHands agent-server base URL"
        }
      }
    }
  },
  "scripts": {
    "build:tailwind": "tailwindcss -i ./src/webview-src/tailwind.css -o ./src/webview-src/tailwind.gen.css --minify",
    "compile": "tsc -p . && npm run build:tailwind && npm run build:webview",
    "watch": "tsc -w -p . & npx tailwindcss -i ./src/webview-src/tailwind.css -o ./src/webview-src/tailwind.gen.css --watch & node --watch esbuild.webview.mjs",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "e2e": "npm run compile && tsc -p tests/e2e/tsconfig.suite.json && tsc -p tsconfig.e2e.json && mocha tests/e2e/out/**/*.test.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p . && tsc -p tsconfig.webview.json",
    "build:webview": "node esbuild.webview.mjs",
    "dev:vscode": "bash scripts/dev-vscode.sh"
  },
  "files": [
    "dist/**",
    "media/**",
    "node_modules/ws/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "bundledDependencies": [
    "ws"
  ],
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.18.6",
    "@types/vscode": "^1.104.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^2.1.4",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.6.1",
    "esbuild": "^0.23.1",
    "eslint": "^9.36.0",
    "jsdom": "^25.0.1",
    "mocha": "^10.8.2",
    "tailwindcss": "^4.1.13",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@openhands/ui": "^1.0.0-beta.9",
    "@types/react": "^19.1.15",
    "@types/react-dom": "^19.1.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.3"
  }
}
